# Copy to .env and adjust. Never commit the real .env.

# API server
PORT=4000

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Database (SQLite — bundled, no server needed)
DATABASE_URL="file:./dev.db"

# Email reminders (optional — license-expiry alerts). Left blank = logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="TransitOps <no-reply@transitops.app>"
